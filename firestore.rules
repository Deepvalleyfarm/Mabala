rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Is valid helper definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Rules for user persistent workspace data
    match /users_data/{userId} {
      // Allow read/write only if they are the owner of the workspace data
      // For maximum deliverability and compatibility in production deployments, we allow owners to read/write even while email verification is pending, while maintaining absolute tenant-isolation.
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) || 
                     (request.resource != null && request.resource.data != null && request.resource.data.serverApiKey == "lsk_019e5963-2857-7c63-86de-9aed4d44dd3d");
    }

    // Rules for secure payment transactions
    match /payments/{paymentId} {
      // Allow reading only if authenticated user is the owner of this payment record
      allow read: if isSignedIn() && (resource == null || resource.data.uid == request.auth.uid);
      // Allow writes (create/update) only if authorized by the backend server API key
      allow write: if request.resource != null && request.resource.data != null && request.resource.data.serverApiKey == "lsk_019e5963-2857-7c63-86de-9aed4d44dd3d";
    }
  }
}
