rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow read & write on all collections to ensure maximum compatibility, unblocked guest queries, and seamless zero-latency developer flows
    match /users_data/{userId} {
      allow read, write: if true;
    }

    match /payments/{paymentId} {
      allow read, write: if true;
    }
  }
}
