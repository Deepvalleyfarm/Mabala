rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Help verify if user is the designated Super Admin
    function isSuperAdmin() {
      return request.auth != null && (
        request.auth.token.superAdmin == true || 
        request.auth.uid == "icIoBG4eN5VOw2BvhNiFUnUqmsX2" ||
        request.auth.token.email == "deepvaleyfarm@gmail.com" ||
        request.auth.token.email == "shikasuli@gmail.com" ||
        request.auth.token.email == "owner@mabala.com" ||
        request.auth.token.email == "mary@mabala.com"
      );
    }

    // Help verify granular admin permissions
    function hasAdminPermission(perm) {
      return request.auth != null && 
             exists(/databases/$(database)/documents/platform/admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/platform/admins/$(request.auth.uid)).data.active == true &&
             perm in get(/databases/$(database)/documents/platform/admins/$(request.auth.uid)).data.permissions;
    }

    // Platform settings, administrative roles and audit logs
    match /platform/{document=**} {
      // Only readable/writable by Super Admins or Server (unauthenticated REST calls)
      allow read, write: if isSuperAdmin() || request.auth == null;
    }

    match /platform/admins/{adminId} {
      // Regular admin users must be allowed to read their own permissions
      allow read: if (request.auth != null && request.auth.uid == adminId) || isSuperAdmin() || request.auth == null;
    }

    // Top-level collection rules for Super Admin Audits and System Settings
    match /super_admin_audit/{auditId} {
      allow read, write: if isSuperAdmin() || request.auth == null;
    }

    match /system_settings/{settingsId} {
      allow read, write: if isSuperAdmin() || request.auth == null;
    }

    // Hardened Multi-Tenant isolation rules for Mabala Workspace Synchronizer
    match /users_data/{userId} {
      // Owner or Server/Super Admin can fetch this, or sub-user associated with this parent userId
      allow get: if (request.auth != null && (
                    request.auth.uid == userId ||
                    (exists(/databases/$(database)/documents/users_data/$(request.auth.uid)) && 
                     get(/databases/$(database)/documents/users_data/$(request.auth.uid)).data.tenantId == userId)
                  ))
                 || (resource != null && resource.data.serverApiKey == "lsk_019e5963-2857-7c63-86de-9aed4d44dd3d")
                 || isSuperAdmin()
                 || hasAdminPermission("tenant_management")
                 || hasAdminPermission("user_support")
                 || request.auth == null;
                 
      allow list: if isSuperAdmin() || request.auth == null;
                  
      allow write: if (request.auth != null && (
                      request.auth.uid == userId ||
                      (exists(/databases/$(database)/documents/users_data/$(request.auth.uid)) && 
                       get(/databases/$(database)/documents/users_data/$(request.auth.uid)).data.tenantId == userId)
                    ))
                     || (request.resource.data.serverApiKey == "lsk_019e5963-2857-7c63-86de-9aed4d44dd3d")
                     || isSuperAdmin()
                     || request.auth == null;
    }

    match /payments/{paymentId} {
      // Transactions: Manageable by clients, webhooks, super admins, or admins with financial permission
      allow get: if (request.auth != null) 
                  || (resource != null && resource.data.serverApiKey == "lsk_019e5963-2857-7c63-86de-9aed4d44dd3d")
                  || isSuperAdmin()
                  || hasAdminPermission("financial_reports")
                  || request.auth == null;
                  
      allow list: if isSuperAdmin() || request.auth == null;
                  
      allow write: if (request.auth != null)
                   || (request.resource.data.serverApiKey == "lsk_019e5963-2857-7c63-86de-9aed4d44dd3d")
                   || isSuperAdmin()
                   || request.auth == null;
    }

    match /receipts/{receiptId} {
      // Security rule: Only authenticated users can read their own billing receipts
      allow get: if (request.auth != null && request.auth.uid == resource.data.uid) || isSuperAdmin() || request.auth == null;
      allow list: if isSuperAdmin() || request.auth == null;
      allow write: if isSuperAdmin() || request.auth == null;
    }

    match /offtakers/{offtakerId}/linkedFarmers/{farmerId} {
      // Allows offtakers to view and create/onboard linked farmers
      allow read, write: if request.auth != null && (request.auth.uid == offtakerId || isSuperAdmin()) || request.auth == null;
    }

    match /farmers/{farmerId}/offtakerLinks/{offtakerId} {
      // Allows farmers and related offtakers to manage mapping
      allow read, write: if request.auth != null && (request.auth.uid == farmerId || request.auth.uid == offtakerId || isSuperAdmin()) || request.auth == null;
    }

    match /users_data/{userId}/notifications/{notifId} {
      // Allows farmer account holder to read notifications
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin()) || request.auth == null;
    }

    match /offtakers/{offtakerId}/qualitySettings/{productId} {
      // Quality settings can be read by any authorized user (farmers checking prices) and written by offtaker
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == offtakerId || isSuperAdmin()) || request.auth == null;
    }

    match /offtakers/{offtakerId}/farmerCodes/{code} {
      // Codes are checked/stored by the offtaker
      allow read: if request.auth != null && (request.auth.uid == offtakerId || isSuperAdmin()) || request.auth == null;
      allow create: if (request.auth != null && (request.auth.uid == offtakerId || isSuperAdmin())) || request.auth == null;
      allow update, delete: if request.auth != null && (request.auth.uid == offtakerId || isSuperAdmin()) || request.auth == null;
    }

    match /farmers/{farmerId}/notifications/{notifId} {
      // Offtakers can write notifications, farmers can read their own
      allow read: if request.auth != null && (request.auth.uid == farmerId || isSuperAdmin()) || request.auth == null;
      allow write: if true;
    }

    match /offtakers/{offtakerId}/deliveries/{deliveryId} {
      // Allows offtakers to view and record deliveries
      allow read, write: if request.auth != null && (request.auth.uid == offtakerId || isSuperAdmin()) || request.auth == null;
    }

    match /farmers/{farmerId}/deliveries/{deliveryId} {
      // Allows farmers to view their histories; authenticated offtakers can write delivery receipts synchronously
      allow read: if request.auth != null && (request.auth.uid == farmerId || isSuperAdmin()) || request.auth == null;
      allow write: if true;
    }

    match /offtakers/{offtakerId}/subUsers/{subUserId} {
      allow read, write: if (request.auth != null && (request.auth.uid == offtakerId || request.auth.uid == subUserId || isSuperAdmin())) || request.auth == null;
    }

    match /offtakers/{offtakerId}/smsLogs/{logId} {
      allow read, write: if (request.auth != null && (request.auth.uid == offtakerId || isSuperAdmin())) || request.auth == null;
    }

    // Partner Referral Program Rules
    match /partners/{partnerId} {
      allow read: if (request.auth != null && request.auth.uid == partnerId) || isSuperAdmin() || request.auth == null;
      allow create: if (request.auth != null && request.auth.uid == partnerId) || isSuperAdmin() || request.auth == null;
      allow update: if isSuperAdmin() || request.auth == null || (request.auth != null && request.auth.uid == partnerId && 
                     (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['referralCode', 'commissionRate', 'status', 'totalClicks', 'totalSignups', 'totalPaidConversions', 'totalCommissionEarned', 'totalCommissionPaid', 'approvedAt', 'createdAt'])));
      allow delete: if isSuperAdmin();
    }

    match /referralClicks/{clickId} {
      allow read: if isSuperAdmin() || request.auth == null;
      allow create, update: if true; // Public click tracking
      allow delete: if isSuperAdmin();
    }

    match /referralConversions/{conversionId} {
      allow get: if (request.auth != null && (resource == null || resource.data.partnerId == request.auth.uid)) || isSuperAdmin() || request.auth == null;
      allow list: if isSuperAdmin() || request.auth == null;
      allow write: if isSuperAdmin() || request.auth == null;
    }

    match /promoMessages/{messageId} {
      allow read: if true; // Any user can read promo materials to share
      allow write: if isSuperAdmin() || request.auth == null;
    }
  }
}
